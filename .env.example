# Puertos host (evitar conflicto con backend 9080/9081)
FRONT_HOST_PORT=9082

# Build Vite: vacío = URLs relativas + nginx proxy (producción/local docker)
VITE_API_VENTAS_URL=
VITE_API_DESPACHOS_URL=

# Nginx proxy hacia backend en host
VENTAS_UPSTREAM=http://host.docker.internal:9080
DESPACHOS_UPSTREAM=http://host.docker.internal:9081

# Solo para npm run dev sin Docker:
# VITE_API_VENTAS_URL=http://localhost:9080
# VITE_API_DESPACHOS_URL=http://localhost:9081
