# Copiar en la EC2 como ~/innovatech-frontend/.env
# cp .env.production.example .env  &&  nano .env

FRONT_HOST_PORT=80

# Vacío en producción: el navegador usa rutas relativas (/api/v1/...)
# y nginx hace proxy hacia los backends privados.
VITE_API_VENTAS_URL=
VITE_API_DESPACHOS_URL=

# Reemplaza con las IPs privadas reales de tus instancias backend en AWS.
VENTAS_UPSTREAM=http://10.0.1.XX:8080
DESPACHOS_UPSTREAM=http://10.0.1.XX:8081
